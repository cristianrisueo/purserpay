# PurserPay — local environment (copy to `.env.local`, fill in, never commit the real file)
# .env.local is gitignored; only this example is tracked.

# --- Public: safe to expose to the browser -----------------------------------
# Next inlines any NEXT_PUBLIC_* var into the client bundle. These two are meant
# to be public (the anon key is protected by Supabase Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# THE build-time network seam (src/lib/tron/config.ts): "mainnet" | "nile".
# Selects the whole chain block (network + PurserPay contract address + USDT token) at
# BUILD time — client and server (serverRead.ts) read the same resolved value, so they
# can never target different networks. REQUIRED: config.ts THROWS at module load if this
# is missing or unrecognized (fail closed — never a silent default, never a guessed
# network). There is deliberately NO runtime toggle; network isolation comes from a
# SEPARATE deployment (prod=mainnet / sandbox=nile, separate Vercel envs AND separate
# Supabase projects). Every non-mainnet build also renders the SANDBOX banner.
NEXT_PUBLIC_TRON_NETWORK=nile

# --- Secret: SERVER ONLY — never expose to the client ------------------------
# No NEXT_PUBLIC_ prefix, so Next never ships these to the browser. The
# service-role key bypasses Row Level Security; use it only in Server Actions /
# Route Handlers via src/lib/supabase/server.ts.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Global pepper for wallet-address hashing (src/lib/crypto.ts → hashWalletAddress).
# Use a long, high-entropy random string. Rotating it re-keys every stored hash,
# so treat it as permanent once compliance data exists. Generate e.g. with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_SALT=<long-random-string>

# AES key for pgcrypto encryption of account-holder PII (billing_profiles.encrypted_pii).
# The server passes it to the encrypt_and_store_pii RPC per call; it is NEVER stored in
# the database and NEVER exposed to the client (no NEXT_PUBLIC_ prefix). Rotating it makes
# all existing ciphertext undecryptable, so treat it as permanent once PII exists. Generate
# e.g. with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PII_ENCRYPTION_KEY=<long-random-string>

# TronGrid API key for the server-side reads the payout gate makes (isSubscriptionActive +
# txid re-verification in src/lib/tron/serverRead.ts). Server-only (no NEXT_PUBLIC_ prefix);
# it never reaches the client.
#   - Nile: OPTIONAL. Leave unset to read without a key.
#   - MAINNET: REQUIRED. Without it TronGrid rate-limits these reads → readSubscriptionActive()
#     returns null → the gate fails CLOSED and a PAYING customer sees the paywall. serverRead.ts
#     THROWS at boot on a mainnet build if this is missing (fail loud, never silent at a payday).
# TRON_PRO_API_KEY=<trongrid-api-key>

# Referral kill switch (src/lib/referral/config.ts). Server-only (no NEXT_PUBLIC_ prefix).
# DEFAULT OFF: the reward mechanic + the dashboard referral card stay dark until this is
# truthy ("1"/"true"/"yes"/"on"). Attribution (/r/{code} cookie) and honoring already-earned
# credit run regardless — only GRANTING new rewards is gated. Leave unset to keep it off.
REFERRALS_ENABLED=true
